---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/astro/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-[#faf9f6] text-[#333] font-sans leading-relaxed">
		<nav
			class="p-6 border-b border-gray-200 bg-white/80 backdrop-blur-md sticky top-0 z-50"
		>
			<div class="max-w-4xl mx-auto flex justify-between items-center">
				<a href="/astro/" class="text-xl font-semibold tracking-tighter"
					>Ishikawa Lab.</a
				>
				<div class="space-x-6 text-sm font-medium">
					<a
						href="/astro/"
						class="hover:text-emerald-600 transition-colors">Home</a
					>
					<a
						href="/astro/about"
						class="hover:text-emerald-600 transition-colors"
						>About</a
					>
				</div>
			</div>
		</nav>
		<main class="max-w-4xl mx-auto p-8 lg:p-12">
			<slot />
		</main>
		<footer class="text-center p-12 text-gray-400 text-xs">
			&copy; 2026 Masakazu Ishikawa
		</footer>
	</body>
</html>
